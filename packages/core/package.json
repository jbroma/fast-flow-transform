{
  "name": "fast-flow-transform",
  "version": "0.0.2",
  "description": "Native Hermes/FFT Flow stripping transform with webpack, rspack, rsbuild, Parcel, Vite, Rollup, Rolldown, and esbuild adapters",
  "keywords": [
    "esbuild",
    "flowtype",
    "parcel",
    "rolldown",
    "rollup",
    "rsbuild",
    "rspack",
    "strip-flow",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/jbroma/fast-flow-transform#readme",
  "bugs": {
    "url": "https://github.com/jbroma/fast-flow-transform/issues"
  },
  "license": "MIT",
  "author": "Jakub Romanczyk <j.romanczyk@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jbroma/fast-flow-transform.git"
  },
  "bin": {
    "fast-flow-transform": "dist/cli/index.js"
  },
  "files": [
    "binding/bindings.cjs",
    "binding/bindings.d.cts",
    "dist",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_LICENSES"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./webpack": {
      "types": "./dist/adapters/webpack.d.ts",
      "import": "./dist/adapters/webpack.js",
      "require": "./dist/adapters/webpack.cjs",
      "default": "./dist/adapters/webpack.js"
    },
    "./rspack": {
      "types": "./dist/adapters/rspack.d.ts",
      "import": "./dist/adapters/rspack.js",
      "require": "./dist/adapters/rspack.cjs",
      "default": "./dist/adapters/rspack.js"
    },
    "./rsbuild": {
      "types": "./dist/adapters/rsbuild.d.ts",
      "import": "./dist/adapters/rsbuild.js",
      "require": "./dist/adapters/rsbuild.cjs",
      "default": "./dist/adapters/rsbuild.js"
    },
    "./rollup": {
      "types": "./dist/adapters/rollup.d.ts",
      "import": "./dist/adapters/rollup.js",
      "default": "./dist/adapters/rollup.js"
    },
    "./rolldown": {
      "types": "./dist/adapters/rolldown.d.ts",
      "import": "./dist/adapters/rolldown.js",
      "default": "./dist/adapters/rolldown.js"
    },
    "./esbuild": {
      "types": "./dist/adapters/esbuild.d.ts",
      "import": "./dist/adapters/esbuild.js",
      "default": "./dist/adapters/esbuild.js"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "import": "./dist/adapters/vite.js",
      "default": "./dist/adapters/vite.js"
    },
    "./parcel": {
      "types": "./dist/adapters/parcel.d.ts",
      "import": "./dist/adapters/parcel.js",
      "default": "./dist/adapters/parcel.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "artifacts": "node ./scripts/package-lifecycle.mts ensure-artifacts-dir && napi artifacts --package-json-path package.json --npm-dir ../../bindings --output-dir ../../artifacts",
    "build": "pnpm run build:bindings && pnpm run build:js",
    "build:bindings": "napi build --platform --release --manifest-path ../../crates/fft_node/Cargo.toml --package-json-path package.json --output-dir binding --js bindings.cjs --dts bindings.d.cts",
    "build:js": "node ./scripts/package-lifecycle.mts clean-dist && tsc -p tsconfig.build.json",
    "postpack": "node ../../scripts/release/cleanup-package-assets.mts",
    "prepack": "pnpm run build:js && node ../../scripts/release/stage-package-assets.mts",
    "publish:bindings": "napi pre-publish -t npm --no-gh-release --package-json-path package.json --npm-dir ../../bindings",
    "prepublishOnly": "pnpm run publish:bindings",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "version:napi": "napi version --package-json-path package.json --npm-dir ../../bindings"
  },
  "dependencies": {
    "source-map": "^0.7.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.5.1",
    "@parcel/plugin": "^2.16.1",
    "@parcel/source-map": "^2.1.1",
    "rollup": "^4.59.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@parcel/plugin": "^2.16.1",
    "@parcel/source-map": "^2.1.1",
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@parcel/plugin": {
      "optional": true
    },
    "@parcel/source-map": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "napi": {
    "binaryName": "fast-flow-transform",
    "packageName": "fast-flow-transform",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
