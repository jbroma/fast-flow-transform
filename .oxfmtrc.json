{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "third_party/**",
    "target/**",
    "node_modules/**",
    "bindings/**",
    "packages/**/dist/**",
    "packages/**/artifacts/**",
    "packages/**/bin/**",
    "packages/fft-loader/bench/fixtures/**",
    "bench/fixtures/**/*.js",
    "test/fixtures/project/**/*.js",
    "test/correctness/**/*.js",
    "test/bundlers/parcel/src/**/*.js"
  ],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "experimentalSortPackageJson": true,
  "experimentalSortImports": {
    "ignoreCase": true,
    "newlinesBetween": true,
    "order": "asc"
  }
}
