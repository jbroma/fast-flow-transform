{
  "name": "@fft/bench",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "node compare.ts",
    "prebenchmark": "pnpm --dir .. sync-binding && cargo build --release -p fft_strip --manifest-path ../Cargo.toml && pnpm --filter fast-flow-transform build",
    "pretest": "pnpm --filter fast-flow-transform build",
    "test": "vitest run --globals compare.test.ts"
  },
  "dependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "babel-plugin-syntax-hermes-parser": "0.32.0",
    "fast-flow-transform": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.0.16"
  }
}
