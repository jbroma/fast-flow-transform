{
  "name": "fast-flow-transform-monorepo",
  "private": true,
  "scripts": {
    "build:loader": "pnpm --filter ./packages/core run build",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "format": "oxfmt . '!test/fixtures/project/**/*.js'",
    "format:check": "oxfmt --check . '!test/fixtures/project/**/*.js'",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "pack:local": "pnpm --filter ./packages/core run pack:local",
    "test:loader:e2e": "pnpm test:loader:e2e:prepare && pnpm --filter @fft-tests/webpack run test && pnpm --filter @fft-tests/rspack run test",
    "test:loader:e2e:prepare": "pnpm build:loader && cargo build --release -p fft_strip",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-syntax-flow": "^7.27.1",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@types/node": "^24.0.0",
    "babel-plugin-transform-flow-enums": "^0.0.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  },
  "packageManager": "pnpm@10.29.2"
}
