{
  "name": "fast-flow-transform-monorepo",
  "private": true,
  "scripts": {
    "benchmark": "turbo run benchmark --log-prefix=none --filter=@fft/bench",
    "build": "turbo run build --log-prefix=none",
    "build:loader": "turbo run build --log-prefix=none --filter=fast-flow-transform",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm codegen:rust:check",
    "codegen:rust": "node scripts/rust-bindings/generate.mts",
    "codegen:rust:check": "node scripts/rust-bindings/generate.mts --check",
    "format": "oxfmt . '!.turbo/**' '!bench/fixtures/**/*.js' '!test/fixtures/project/**/*.js' '!test/bundlers/parcel/src/**/*.js'",
    "format:check": "oxfmt --check . '!.turbo/**' '!bench/fixtures/**/*.js' '!test/fixtures/project/**/*.js' '!test/bundlers/parcel/src/**/*.js'",
    "lint": "oxlint . --ignore-pattern 'test/bundlers/parcel/src/**/*.js'",
    "lint:fix": "oxlint --fix . --ignore-pattern 'test/bundlers/parcel/src/**/*.js'",
    "sync-binding": "cargo build --release -p fft_node && node scripts/sync-binding.mts",
    "e2e": "turbo run e2e --log-prefix=none --filter=@fft-tests/*",
    "e2e:parcel": "turbo run e2e --log-prefix=none --filter=@fft-tests/parcel",
    "e2e:esbuild": "turbo run e2e --log-prefix=none --filter=@fft-tests/esbuild",
    "e2e:rolldown": "turbo run e2e --log-prefix=none --filter=@fft-tests/rolldown",
    "e2e:rollup": "turbo run e2e --log-prefix=none --filter=@fft-tests/rollup",
    "e2e:rsbuild": "turbo run e2e --log-prefix=none --filter=@fft-tests/rsbuild",
    "e2e:rspack": "turbo run e2e --log-prefix=none --filter=@fft-tests/rspack",
    "e2e:vite": "turbo run e2e --log-prefix=none --filter=@fft-tests/vite",
    "e2e:webpack": "turbo run e2e --log-prefix=none --filter=@fft-tests/webpack",
    "local-registry:publish": "node scripts/local-registry/publish.mts",
    "typecheck": "turbo run typecheck --log-prefix=none"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5",
    "verdaccio": "6.1.6"
  },
  "packageManager": "pnpm@10.29.2"
}
