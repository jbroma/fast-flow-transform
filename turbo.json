{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "benchmark": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "build": {
      "dependsOn": ["//#sync-binding", "^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "e2e": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "//#sync-binding": {
      "inputs": [
        "Cargo.lock",
        "Cargo.toml",
        "crates/**",
        "scripts/sync-binding.ts"
      ],
      "outputs": [
        "bindings/*/*.node",
        "packages/core/native/**",
        "target/release/fast-flow-transform.*.node"
      ]
    }
  }
}
